<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.tableau.extension.dashboard-export" extension-version="1.0.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name">Dashboard Excel Exporter</name>
    <description resource-id="description">Export all dashboard worksheets with applied filters to a single Excel file — one sheet per chart, just like Metabase.</description>
    <author name="Dashboard Export Extension" email="support@example.com" organization="Custom Extensions" website="https://example.com" />
    <min-api-version>1.7</min-api-version>
    <source-location>
      <url>https://piyushsharma-greyb.github.io/tableau-exporter/</url>
    </source-location>
    <icon></icon>
    <permissions>
      <permission>full data</permission>
    </permissions>
  </dashboard-extension>
</manifest>
